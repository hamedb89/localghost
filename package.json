{
  "name": "@hamedb89/localghost",
  "version": "0.1.0",
  "description": "Friendly local hostnames for app repos, powered by /etc/hosts, Caddy, and Vite.",
  "type": "module",
  "bin": {
    "localghost": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "localghost",
    "local-dev",
    "localhost",
    "hosts",
    "caddy",
    "vite",
    "https",
    "developer-tools"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup src/index.ts src/vite.ts src/cli.ts --format esm --dts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run",
    "release:check": "npm run typecheck && npm run build && npm pack --dry-run"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "execa": "^9.0.0"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": ">=5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamedb89/localghost.git"
  },
  "homepage": "https://github.com/hamedb89/localghost#readme",
  "bugs": {
    "url": "https://github.com/hamedb89/localghost/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "npm@10.9.8",
  "overrides": {
    "esbuild": "0.28.1"
  }
}
